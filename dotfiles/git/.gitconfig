[credential]
	helper = manager
	useHttpPath = true
	azreposCredentialType = oauth
	credentialStore = secretservice
[user]
	email = artem_vovchenko@epam.com
	name = Artem Vovchenko
[init]
	defaultBranch = main
[http]
	postBuffer = 157286400
[pull]
	rebase = false
[core]
	autocrlf = false
	pager = delta
[safe]
	directory = *
[interactive]
	diffFilter = delta --color-only --features=diff-so-fancy
[delta]
	navigate = true
	line-numbers = true
[credential "https://dev.azure.com"]
	useHttpPath = true
[credential "azrepos:org/EPMP-MVIS"]
	azureAuthority = https://login.microsoftonline.com/b41b72d0-4e9f-4c26-8a69-f949f367c91d
	username = Artem_Vovchenko@epam.com
