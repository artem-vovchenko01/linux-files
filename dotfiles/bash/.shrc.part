    export GROK_API_KEY="$(cat "$HOME/.grok-api-key")"
fi

if command -v fzf >/dev/null 2>&1; then
    if [ "$_SHRC_SHELL" = zsh ]; then
        eval "$(fzf --zsh)"
    else
        eval "$(fzf --bash)"
    fi
fi

if [ "$_SHRC_SHELL" = bash ]; then
    # Unlimited history size
    HISTSIZE=-1
    HISTFILESIZE=-1

    # Append to history file instead of overwriting
    shopt -s histappend

    # Write history after every command.
    case ";${PROMPT_COMMAND:-};" in
        *";history -a;"*) ;;
        *) PROMPT_COMMAND="history -a${PROMPT_COMMAND:+; $PROMPT_COMMAND}" ;;
    esac

    # Don't ignore any commands.
    HISTCONTROL=
fi

# Store history with timestamps (optional but useful)
# HISTTIMEFORMAT="%F %T  "


if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv "$_SHRC_SHELL")"
fi

# Starship prompt
if command -v starship >/dev/null 2>&1; then
    eval "$(starship init "$_SHRC_SHELL")"
fi

unset _SHRC_SHELL _SHRC_SHELL_PROC
