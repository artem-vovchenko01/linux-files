#############################
# SETTINGS
##############################

set -o vi

##############################
# EXPORTS
##############################

_SHRC_SHELL_PROC=$(readlink /proc/$$/exe 2>/dev/null || printf '%s\n' "${SHELL:-}")
case "$_SHRC_SHELL_PROC" in
    *zsh*) _SHRC_SHELL=zsh ;;
    *) _SHRC_SHELL=bash ;;
esac

_shrc_path_remove() {
    [ -n "${PATH:-}" ] || return 0
    _shrc_new_path=""
    _shrc_old_ifs=$IFS
    IFS=':'
    for _shrc_path_part in $PATH; do
        [ "$_shrc_path_part" = "$1" ] && continue
        if [ -z "$_shrc_new_path" ]; then
            _shrc_new_path="$_shrc_path_part"
        else
            _shrc_new_path="$_shrc_new_path:$_shrc_path_part"
        fi
    done
    IFS=$_shrc_old_ifs
    PATH=$_shrc_new_path
    unset _shrc_new_path _shrc_old_ifs _shrc_path_part
}

_shrc_path_append() {
    [ -d "$1" ] || return 0
    case ":${PATH:-}:" in
        *:"$1":*) ;;
        *) PATH="${PATH:+$PATH:}$1" ;;
    esac
}

_shrc_path_prepend() {
    [ -d "$1" ] || return 0
    case ":${PATH:-}:" in
        *:"$1":*) ;;
        *) PATH="$1${PATH:+:$PATH}" ;;
    esac
}

_shrc_source_if_readable() {
    [ -r "$1" ] && . "$1"
}

# Remove stale pyenv env inherited from an old session.
unset PYENV_ROOT PYENV_SHELL
_shrc_path_remove "$HOME/.pyenv/shims"

# CARGO_HOME=~/.cargo/bin
# DOTNET_TOOLS_HOME=~/.dotnet/tools
# export PATH=$PATH:~/.local/share/flatpak/exports/share
# export PATH="$PATH:$GEM_HOME/bin"
# export PATH="$PATH:$CARGO_HOME"
# export PATH="$PATH:$DOTNET_TOOLS_HOME"

_shrc_path_append "$HOME/.local/bin"
export PATH
export EDITOR=nvim
# Workaround: broken IPv6 dual-stack hangs Python MSAL on login.microsoftonline.com (Azure CLI / Azure MCP).
export RES_OPTIONS="no-aaaa"

# Custom scripts
if [ -d "$HOME/linux-files/scripts" ]; then
    while IFS= read -r dir; do
        _shrc_path_append "$dir"
    done <<EOF
$(find -L "$HOME/linux-files/scripts" -type d)
EOF
    export PATH
fi

# EPAM scripts
_shrc_path_append "$HOME/DATA/EPAM_resources/scripts"
export PATH

##############################
# OPTIONAL PROGRAMMING TOOLS
##############################

# npm
if [ -d "$HOME/.npm-global/bin" ]; then
    _shrc_path_prepend "$HOME/.npm-global/bin"
fi

# Flutter/Dart
if [ -d "$HOME/Pobrane/flutter/flutter" ]; then
    _shrc_path_append "$HOME/Pobrane/flutter/flutter/bin"
fi
_shrc_path_append "$HOME/.pub-cache/bin"

# Rust/Cargo
_shrc_path_append "$HOME/.cargo/bin"

# Personal compiled binaries
_shrc_path_append "$HOME/.my-c-bin"

# Apache Spark / PySpark
_SHRC_SPARK_HOME=/opt/apache-spark
_SHRC_SPARK_JAVA_HOME=/usr/lib/jvm/java-21-openjdk

if [ -d "$_SHRC_SPARK_HOME" ]; then
    export SPARK_HOME=$_SHRC_SPARK_HOME
    _shrc_path_append "$SPARK_HOME/bin"
    _shrc_path_append "$SPARK_HOME/sbin"
fi

export PATH

_shrc_spark_java_major() {
    [ -x "$_SHRC_SPARK_JAVA_HOME/bin/java" ] || return 1
    "$_SHRC_SPARK_JAVA_HOME/bin/java" -version 2>&1 |
        sed -n '1s/.*version "\([0-9][0-9]*\).*/\1/p'
}

_shrc_spark_with_java() {
    local _shrc_spark_major

    if ! command -v "$1" >/dev/null 2>&1; then
        printf 'Spark command not found: %s\n' "$1" >&2
        return 127
    fi

    if [ ! -x "$_SHRC_SPARK_JAVA_HOME/bin/java" ]; then
        printf 'Spark Java not found: %s/bin/java\n' "$_SHRC_SPARK_JAVA_HOME" >&2
        return 127
    fi

    _shrc_spark_major="$(_shrc_spark_java_major)"
    case "$_shrc_spark_major" in
        17|21) ;;
        *)
            printf 'Spark requires Java 17 or 21; found Java %s at %s\n' "${_shrc_spark_major:-unknown}" "$_SHRC_SPARK_JAVA_HOME" >&2
            return 1
            ;;
    esac

    JAVA_HOME=$_SHRC_SPARK_JAVA_HOME PATH=$_SHRC_SPARK_JAVA_HOME/bin:$PATH command "$@"
}

_shrc_pyspark_notebook() {
    if ! command -v jupyter >/dev/null 2>&1; then
        _shrc_spark_with_java pyspark "$@"
        return $?
    fi

    PYSPARK_DRIVER_PYTHON=jupyter \
        PYSPARK_DRIVER_PYTHON_OPTS=notebook \
        _shrc_spark_with_java pyspark "$@"
}

_shrc_spark_java_supported() {
    case "$(_shrc_spark_java_major)" in
        17|21) return 0 ;;
        *) return 1 ;;
    esac
}

_shrc_alias_spark_command() {
    command -v "$1" >/dev/null 2>&1 || return 0
    alias "$1=_shrc_spark_with_java $1"
}

_shrc_alias_pyspark_notebook() {
    command -v pyspark >/dev/null 2>&1 || return 0
    alias pyspark='_shrc_pyspark_notebook'
}

if [ -n "${SPARK_HOME:-}" ] && _shrc_spark_java_supported; then
    _shrc_alias_pyspark_notebook
    _shrc_alias_spark_command spark-shell
    _shrc_alias_spark_command spark-submit
    _shrc_alias_spark_command spark-sql
fi

##############################
# FUNCTIONS
##############################

contains() {
    string="$1"
    substring="$2"
    if test "${string#*$substring}" != "$string"
    then
        return 0    # $substring is in $string
    else
        return 1    # $substring is not in $string
    fi
}

function vicd {
    if command -v vifm >/dev/null 2>&1; then
        local dst="$(command vifm --choose-dir - "$@")"
    elif command -v lf >/dev/null 2>&1; then
        local dst="$(command lf -print-last-dir "$@")"
    else
        echo 'Neither vifm nor lf is available'
        return 1
    fi
    if [ -z "$dst" ]; then
        echo 'Directory picking cancelled/failed'
        return 1
    fi
    cd "$dst"
}

function mirrors {
    sudo cp /etc/pacman.d/mirrorlist "/etc/pacman.d/mirrorlist.bac$(date)"
    sudo reflector --latest 20 --protocol https --sort rate --save /etc/pacman.d/mirrorlist
}

function abs_filename {
  # $1 : relative filename
  echo "$(cd "$(dirname "$1")" && pwd)/$(basename "$1")"
}

function date_sync {
    sudo date -s "$(wget -qSO- --max-redirect=0 google.com 2>&1 | grep Date: | cut -d' ' -f5-8)Z" 
}

function check_battery {
    [ -r /sys/class/power_supply/BAT1/capacity ] && cat /sys/class/power_supply/BAT1/capacity
}

function ssh_add_startup_keys {
    SSH_ADD_ON_STARTUP="$HOME/.ssh/on_startup"
    [ -d "$SSH_ADD_ON_STARTUP" ] || return 0
    for key in "$SSH_ADD_ON_STARTUP"/*; do
        [ -f "$key" ] && ssh-add "$key"
    done
}

##############################
# COMPLETIONS
##############################

# complete -C '/usr/bin/aws_completer' aws
# bash-completion
if [ "$_SHRC_SHELL" = bash ]; then
    if [ -r /usr/share/bash-completion/bash_completion ]; then
        . /usr/share/bash-completion/bash_completion
    elif [ -r /etc/profile.d/bash_completion.sh ]; then
        . /etc/profile.d/bash_completion.sh
    fi
fi

##############################
# SOURCES
##############################

# [[ -e /usr/share/doc/pkgfile/command-not-found.zsh ]] && source /usr/share/doc/pkgfile/command-not-found.zsh

ZSH_SYNTAX_HL_ARCH=/usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
ZSH_AUTOSUGG_ARCH=/usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

ZSH_SYNTAX_HL_DEB=/usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
ZSH_AUTOSUGG_DEB=/usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh

ZSH_POWERLEVEL10K_THEME_ARCH=/usr/share/zsh-theme-powerlevel10k/powerlevel10k.zsh-theme
ZSH_POWERLEVEL10K_THEME_OTHER=~/powerlevel10k/powerlevel10k.zsh-theme

if [ "$_SHRC_SHELL" = zsh ]; then
   # assume Zsh
  _shrc_source_if_readable "$ZSH_SYNTAX_HL_ARCH"
  _shrc_source_if_readable "$ZSH_AUTOSUGG_ARCH"

  _shrc_source_if_readable "$ZSH_SYNTAX_HL_DEB"
  _shrc_source_if_readable "$ZSH_AUTOSUGG_DEB"

  _shrc_source_if_readable "$ZSH_POWERLEVEL10K_THEME_ARCH"
  _shrc_source_if_readable "$ZSH_POWERLEVEL10K_THEME_OTHER"
fi

